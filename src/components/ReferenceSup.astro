---
interface Props {
	number: number;
	href: string;
	label: string;
	popoverEnabled?: boolean;
}

const { number, href, label, popoverEnabled = true } = Astro.props;
---

<span class="reference-sup ml-0.5 inline-block align-super text-[0.65em] leading-none">
	<a
		href="#references"
		class="font-semibold text-[#780000] transition-colors hover:text-[#c1121f]"
		aria-label={`Reference ${number}: scroll to references`}
	>
		{number}
	</a>
	{popoverEnabled && (
		<span class="reference-popover-wrap absolute left-full top-1/2 z-50 block w-[min(26rem,calc(100vw-2rem))] -translate-y-1/2 pl-3">
			<span class="block rounded-md border border-black/10 bg-white p-3 text-xs normal-case leading-relaxed text-black shadow-lg">
				<span class="block font-semibold text-black">Reference {number}</span>
				<span class="mt-1 flex items-start gap-2">
					<a
						href={href}
						target="_blank"
						rel="noopener noreferrer"
						class="min-w-0 flex-1 text-[#780000] underline hover:text-[#c1121f]"
					>
						{label}
					</a>
					<span class="inline-flex shrink-0 flex-col items-center">
						<button
							type="button"
							class="inline-flex h-7 w-7 items-center justify-center rounded border border-black/20 text-black hover:bg-black hover:text-white"
							data-copy-link={href}
							aria-label="Copy source URL"
						>
							<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="h-4 w-4">
								<path d="M9 2a2 2 0 0 0-2 2v2H6a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h9a2 2 0 0 0 2-2h1a2 2 0 0 0 2-2V8l-6-6H9Zm5 1.5L18.5 8H15a1 1 0 0 1-1-1V3.5ZM9 4h3v3a3 3 0 0 0 3 3h3v10h-1V8a2 2 0 0 0-2-2H9V4Zm-3 4h9v12H6V8Z"/>
							</svg>
						</button>
						<span class="mt-1 text-[9px] font-semibold uppercase tracking-wide text-[#780000] opacity-0 transition-opacity duration-150" data-copy-status>
							Copied
						</span>
					</span>
				</span>
			</span>
		</span>
	)}
</span>

<style>
	.reference-sup {
		position: relative;
	}

	.reference-popover-wrap {
		opacity: 0;
		visibility: hidden;
		pointer-events: none;
		transition: opacity 180ms ease;
	}

	@media (max-width: 1023px) {
		.reference-popover-wrap {
			position: fixed;
			left: 50%;
			top: auto;
			bottom: 1rem;
			transform: translateX(-50%);
			width: min(26rem, calc(100vw - 2rem));
			padding-left: 0;
		}
	}

	.reference-sup:hover .reference-popover-wrap {
		opacity: 1;
		visibility: visible;
		pointer-events: auto;
	}
</style>
