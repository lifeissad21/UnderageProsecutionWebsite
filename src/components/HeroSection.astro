---
import { Picture } from 'astro:assets';

type MediaSlot = {
	src: string;
	alt: string;
};

type HeroFrame = {
	mediaSlots: MediaSlot[];
};

const restingSubtext = 'Examining how justice systems respond to youth offenses through accountability, rehabilitation, and long-term public safety outcomes.';
const heroBase = import.meta.env.BASE_URL;
const heroPath = (fileName: string): string => `${heroBase}hero/${fileName}`;

const heroFrames: HeroFrame[] = [
	{
		mediaSlots: [
			{
				src: heroPath('opening-vox.jpg'),
				alt: 'Teen in juvenile detention setting',
			},
		],
	},
	{
		mediaSlots: [
			{
				src: heroPath('too-young-latimes.jpg'),
				alt: 'Youth in California justice facility',
			},
			{
				src: heroPath('too-young-cdf.jpg'),
				alt: 'Youth justice advocacy portrait',
			},
		],
	},
	{
		mediaSlots: [
			{
				src: heroPath('sentenced-gpb.jpg'),
				alt: 'Teen in correctional setting',
			},
		],
	},
	{
		mediaSlots: [
			{
				src: heroPath('juvenile-justice-cincinnati.jpg'),
				alt: 'Ohio youth detention center still image',
			},
		],
	},
];
---

<section id="hero" class="hero-shell relative flex min-h-screen items-center overflow-hidden bg-black px-6 py-20 md:px-12 md:py-24">
	<div class="absolute inset-0 bg-[radial-gradient(circle_at_50%_20%,rgba(193,18,31,0.22),transparent_55%)]"></div>
	<div class="absolute inset-0 bg-[linear-gradient(120deg,rgba(0,0,0,0.75),rgba(0,0,0,0.55))]"></div>

	<div class="relative mx-auto w-full max-w-7xl">
		<div class="grid items-center gap-10 lg:grid-cols-[minmax(0,1.1fr)_minmax(0,0.9fr)] lg:gap-12">
			<div class="hero-copy min-w-0">
				<h1 id="hero-main-title" class="hero-main-title mt-6 text-5xl font-black uppercase leading-[0.95] text-[#c1121f] sm:text-6xl md:text-7xl lg:text-8xl">
					Underage Prosecution
				</h1>
				<div id="hero-byline" class="hero-byline is-hidden">
					<p class="mt-4 text-sm font-medium tracking-wide text-white/85 md:text-base">
						By Minh Nguyen, George Mathew, Noah Kim, and Brian Zhou
					</p>
					<p class="mt-1 text-xs font-semibold uppercase tracking-[0.18em] text-white/65 md:text-sm">
						GSMST
					</p>
				</div>
				<p id="hero-subtext" class="hero-subtext is-hidden mt-8 max-w-2xl text-base leading-8 text-white/70 md:text-lg">
					{restingSubtext}
				</p>
			</div>

			<aside class="hero-media-panel relative min-h-[24rem] w-full min-w-0 sm:min-h-[28rem] lg:translate-x-10" aria-live="polite">
				{heroFrames.map((frame, frameIndex) => (
					<div class={`hero-frame ${frameIndex === 0 ? 'is-active' : ''}`} data-frame={frameIndex}>
						{frame.mediaSlots.length === 2 ? (
							<div class="hero-media-overlap">
								{frame.mediaSlots.map((slot) => (
									<div class="hero-media-slot hero-media-overlap-slot">
										<figure class="hero-media-card">
											<Picture src={slot.src} formats={['webp']} alt={slot.alt} class="h-full w-full object-cover" width={1600} height={1000} loading="eager" />
										</figure>
									</div>
								))}
							</div>
						) : (
							<div class="grid gap-3">
								{frame.mediaSlots.map((slot) => (
									<div class="hero-media-slot">
										<figure class="hero-media-card">
											<Picture src={slot.src} formats={['webp']} alt={slot.alt} class="h-full w-full object-cover" width={1600} height={1000} loading="eager" />
										</figure>
									</div>
								))}
							</div>
						)}
					</div>
				))}
			</aside>
		</div>
	</div>

	<button id="hero-replay" type="button" class="hero-replay-btn" hidden aria-label="Replay hero sequence">
		<svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true" class="h-4 w-4">
			<path d="M8 5.14v13.72a1 1 0 0 0 1.53.85l10.28-6.86a1 1 0 0 0 0-1.66L9.53 4.29A1 1 0 0 0 8 5.14Z" />
		</svg>
		<span>Play Intro</span>
	</button>
</section>

<style>
	.hero-main-title {
		display: block;
		max-width: 12ch;
		min-height: 2.1em;
		opacity: 1;
		transform: translateY(0);
		transition:
			opacity 420ms ease,
			transform 420ms ease;
	}

	.hero-main-title.is-fading {
		opacity: 0;
		transform: translateY(16px);
	}

	.hero-subtext {
		opacity: 1;
		transform: translateY(0);
		transition:
			opacity 360ms ease,
			transform 360ms ease;
	}

	.hero-byline {
		opacity: 1;
		transform: translateY(0);
		transition:
			opacity 300ms ease,
			transform 300ms ease;
	}

	.hero-byline.is-hidden {
		opacity: 0;
		transform: translateY(10px);
		pointer-events: none;
	}

	.hero-subtext.is-hidden {
		opacity: 0;
		transform: translateY(12px);
		pointer-events: none;
	}

	.hero-media-panel {
		overflow: visible;
	}

	.hero-frame {
		position: absolute;
		inset: 0.5rem;
		opacity: 0;
		transform: translateY(14px);
		pointer-events: none;
		overflow: visible;
		transition:
			opacity 420ms ease,
			transform 420ms ease;
	}

	.hero-frame.is-active {
		opacity: 1;
		transform: translateY(0);
		pointer-events: auto;
	}

	.hero-media-slot {
		height: auto;
		overflow: visible;
		box-shadow: 0 18px 35px rgb(0 0 0 / 0.38);
	}

	.hero-media-card {
		display: grid;
		gap: 0.4rem;
		margin: 0;
	}

	.hero-media-card picture {
		display: block;
		height: 23rem;
		overflow: hidden;
		border: 0;
	}

	.hero-media-overlap {
		position: relative;
		height: 28.8rem;
		width: 100%;
	}

	.hero-media-overlap-slot {
		position: absolute;
		width: min(62%, 22rem);
		height: auto;
	}

	.hero-media-overlap-slot .hero-media-card picture {
		height: 17.2rem;
	}

	.hero-media-overlap-slot .hero-media-card {
		position: relative;
		display: block;
	}

	.hero-media-overlap-slot:nth-child(1) {
		left: 0;
		top: 0.4rem;
		transform: translate(-8px, -10px);
		z-index: 1;
	}

	.hero-media-overlap-slot:nth-child(2) {
		right: 0;
		bottom: 0.4rem;
		transform: translate(8px, 10px);
		z-index: 2;
	}

	.hero-replay-btn {
		position: absolute;
		right: 1.25rem;
		bottom: 1.25rem;
		display: inline-flex;
		align-items: center;
		gap: 0.45rem;
		border-radius: 999px;
		border: 1px solid rgb(193 18 31 / 0.7);
		background: rgb(0 0 0 / 0.5);
		padding: 0.55rem 0.85rem;
		font-size: 0.7rem;
		font-weight: 700;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		color: #c1121f;
		transition:
			background-color 200ms ease,
			color 200ms ease,
			border-color 200ms ease;
	}

	.hero-replay-btn:hover {
		border-color: #c1121f;
		background: #c1121f;
		color: white;
	}

	@media (max-width: 1023px) {
		.hero-frame {
			position: absolute;
			inset: 0.75rem;
		}

		.hero-media-slot {
			height: auto;
		}

		.hero-media-card picture {
			height: 15.5rem;
		}

		.hero-media-overlap {
			height: 21rem;
		}

		.hero-media-overlap-slot {
			width: min(66%, 14.5rem);
			height: auto;
		}

		.hero-media-overlap-slot .hero-media-card picture {
			height: 11.5rem;
		}

		.hero-media-overlap-slot:nth-child(1) {
			left: 0;
			top: 0.35rem;
			transform: translate(-5px, -6px);
		}

		.hero-media-overlap-slot:nth-child(2) {
			right: 0;
			bottom: 0.35rem;
			transform: translate(5px, 6px);
		}
	}
</style>

<script>
	(() => {
		const root = document.getElementById('hero');
		if (!root) return;

		const titleEl = root.querySelector('#hero-main-title');
		const bylineEl = root.querySelector('#hero-byline');
		const subtextEl = root.querySelector('#hero-subtext');
		const replayButton = root.querySelector('#hero-replay');
		const frames = Array.from(root.querySelectorAll('.hero-frame'));

		if (!(titleEl instanceof HTMLElement) || !(bylineEl instanceof HTMLElement) || !(subtextEl instanceof HTMLElement) || !(replayButton instanceof HTMLButtonElement)) {
			return;
		}

		const phrases = [
			'Underage Prosecution',
			'Too young to vote.',
			'Old enough to be sentenced.',
			'This is juvenile justice.',
		];

		const introDelayMs = 2100;
		const phraseDelayMs = 2600;
		let isPlaying = false;
		let animationAborted = false;
		let timeoutIds: number[] = [];

		const sleep = (ms: number) => new Promise<void>((resolve) => {
			const id = setTimeout(resolve, ms);
			timeoutIds.push(id);
		});

		const clearAllTimeouts = () => {
			timeoutIds.forEach(id => clearTimeout(id));
			timeoutIds = [];
		};

		const setFrame = (index: number) => {
			frames.forEach((frame, frameIndex) => {
				frame.classList.toggle('is-active', frameIndex === index);
			});
		};

		const setTitle = async (nextText: string) => {
			titleEl.classList.add('is-fading');
			await sleep(320);
			titleEl.textContent = nextText;
			titleEl.classList.remove('is-fading');
		};

		const setRestingHero = () => {
			titleEl.textContent = 'Underage Prosecution';
			bylineEl.classList.remove('is-hidden');
			subtextEl.classList.remove('is-hidden');
			setFrame(0);
		};

		const playSequence = async () => {
			if (isPlaying) return;
			isPlaying = true;
			animationAborted = false;

			replayButton.hidden = true;
			bylineEl.classList.add('is-hidden');
			subtextEl.classList.add('is-hidden');
			setFrame(0);
			await sleep(introDelayMs);

			if (animationAborted) {
				isPlaying = false;
				return;
			}

			for (let step = 1; step < phrases.length; step++) {
				if (animationAborted) {
					isPlaying = false;
					return;
				}

				setFrame(step);
				await setTitle(phrases[step]);
				await sleep(phraseDelayMs);
			}

			setRestingHero();
			replayButton.hidden = false;
			isPlaying = false;
		};

		// Intersection Observer to pause animation when out of view
		const observer = new IntersectionObserver((entries) => {
			entries.forEach((entry) => {
				if (!entry.isIntersecting && isPlaying) {
					// Scrolled out of view - abort animation
					animationAborted = true;
					clearAllTimeouts();
					isPlaying = false;
					replayButton.hidden = false;
					setRestingHero();
				}
			});
		}, { threshold: 0.1 });

		observer.observe(root);

		playSequence();

		replayButton.addEventListener('click', () => {
			playSequence();
		});
	})();
</script>
