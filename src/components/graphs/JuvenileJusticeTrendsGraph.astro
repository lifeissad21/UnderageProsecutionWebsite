---
import ReferenceSup from '../ReferenceSup.astro';

type Row = {
	year: number;
	delinquency: number | null;
	juvenileArrests: number | null;
	detainedYouth: number | null;
};

const data: Row[] = [
	{ year: 1990, delinquency: 184.403281, juvenileArrests: 282.106868, detainedYouth: null },
	{ year: 1991, delinquency: 201.597851, juvenileArrests: 296.486794, detainedYouth: null },
	{ year: 1992, delinquency: 211.821267, juvenileArrests: 297.213211, detainedYouth: null },
	{ year: 1993, delinquency: 219.555996, juvenileArrests: 313.151582, detainedYouth: null },
	{ year: 1994, delinquency: 238.758484, juvenileArrests: 347.380259, detainedYouth: null },
	{ year: 1995, delinquency: 254.482466, juvenileArrests: 350.786857, detainedYouth: null },
	{ year: 1996, delinquency: 259.785068, juvenileArrests: 374.571678, detainedYouth: null },
	{ year: 1997, delinquency: 262.429299, juvenileArrests: 368.373581, detainedYouth: 247.9 },
	{ year: 1998, delinquency: 250.296946, juvenileArrests: 336.558208, detainedYouth: 246.08 },
	{ year: 1999, delinquency: 241.855204, juvenileArrests: 310.564165, detainedYouth: null },
	{ year: 2000, delinquency: 239.338235, juvenileArrests: 303.362785, detainedYouth: 255.34 },
	{ year: 2001, delinquency: 235.94457, juvenileArrests: 293.865126, detainedYouth: null },
	{ year: 2002, delinquency: 234.063914, juvenileArrests: 299.169829, detainedYouth: 255.27 },
	{ year: 2003, delinquency: 233.427602, juvenileArrests: 293.953609, detainedYouth: null },
	{ year: 2004, delinquency: 233.32862, juvenileArrests: 291.544586, detainedYouth: null },
	{ year: 2005, delinquency: 232.621606, juvenileArrests: 288.460523, detainedYouth: null },
	{ year: 2006, delinquency: 223.95362, juvenileArrests: 297.050517, detainedYouth: null },
	{ year: 2007, delinquency: 225.028281, juvenileArrests: 291.865694, detainedYouth: 243.59 },
	{ year: 2008, delinquency: 222.242647, juvenileArrests: 282.265281, detainedYouth: null },
	{ year: 2009, delinquency: 203.761312, juvenileArrests: 257.064731, detainedYouth: null },
	{ year: 2010, delinquency: 186.722285, juvenileArrests: 232.905998, detainedYouth: null },
	{ year: 2011, delinquency: 169.994344, juvenileArrests: 208.456127, detainedYouth: 187.77 },
	{ year: 2012, delinquency: 156.122738, juvenileArrests: 186.99755, detainedYouth: null },
	{ year: 2013, delinquency: 141.14819, juvenileArrests: 154.495725, detainedYouth: 135.87 },
	{ year: 2014, delinquency: 131.589367, juvenileArrests: 145.137356, detainedYouth: null },
	{ year: 2015, delinquency: 124.137443, juvenileArrests: 130.647396, detainedYouth: 122.88 },
	{ year: 2016, delinquency: 116.911765, juvenileArrests: null, detainedYouth: null },
	{ year: 2017, delinquency: 110.364819, juvenileArrests: 115.095498, detainedYouth: 112.98 },
	{ year: 2018, delinquency: 103.803733, juvenileArrests: 103.584421, detainedYouth: null },
	{ year: 2019, delinquency: 100, juvenileArrests: 100, detainedYouth: 100 },
	{ year: 2020, delinquency: 70.814496, juvenileArrests: 60.857087, detainedYouth: null },
	{ year: 2021, delinquency: 61.2415158, juvenileArrests: null, detainedYouth: 64.92 },
	{ year: 2022, delinquency: 77.7007919, juvenileArrests: 68.2564125, detainedYouth: null },
	{ year: 2023, delinquency: null, juvenileArrests: 75.4134086, detainedYouth: 80.52 },
];

const WIDTH = 920;
const HEIGHT = 360;
const PADDING = { top: 24, right: 28, bottom: 42, left: 54 };
const INNER_WIDTH = WIDTH - PADDING.left - PADDING.right;
const INNER_HEIGHT = HEIGHT - PADDING.top - PADDING.bottom;

const years = data.map((d) => d.year);
const minYear = Math.min(...years);
const maxYear = Math.max(...years);

const allValues = data.flatMap((d) => [d.delinquency, d.juvenileArrests, d.detainedYouth]).filter((v): v is number => v !== null);
const minValue = Math.min(...allValues);
const maxValue = Math.max(...allValues);

const yMin = Math.floor((minValue - 10) / 10) * 10;
const yMax = Math.ceil((maxValue + 10) / 10) * 10;
const yStep = 50;
const yTicks: number[] = [];
for (let tick = yMin; tick <= yMax; tick += yStep) {
	yTicks.push(tick);
}

const xTicks = data.filter((d) => d.year % 5 === 0 || d.year === maxYear).map((d) => d.year);

const x = (year: number): number => PADDING.left + ((year - minYear) / (maxYear - minYear)) * INNER_WIDTH;
const y = (value: number): number => PADDING.top + ((yMax - value) / (yMax - yMin)) * INNER_HEIGHT;

type MetricKey = 'delinquency' | 'juvenileArrests' | 'detainedYouth';

type Metric = {
	key: MetricKey;
	label: string;
	color: string;
	reference: number;
	href: string;
	popoverLabel: string;
};

const metrics: Metric[] = [
	{
		key: 'juvenileArrests',
		label: 'Juvenile arrests',
		color: '#b91c1c',
		reference: 7,
		href: 'https://counciloncj.org/who-gets-arrested-in-america-trends-across-four-decades-1980-2024/',
		popoverLabel: 'Data source: Council on Criminal Justice (Who Gets Arrested in America)',
	},
	{
		key: 'delinquency',
		label: 'Delinquency cases',
		color: '#0f766e',
		reference: 7,
		href: 'https://counciloncj.org/who-gets-arrested-in-america-trends-across-four-decades-1980-2024/',
		popoverLabel: 'Data source: Council on Criminal Justice (Who Gets Arrested in America)',
	},
	{
		key: 'detainedYouth',
		label: 'Detained youth (recently admitted)',
		color: '#1d4ed8',
		reference: 29,
		href: 'https://ojjdp.ojp.gov/statistical-briefing-book/data-analysis-tools/ezajcs',
		popoverLabel: 'Data source: OJJDP Statistical Briefing Book Data Analysis Tools (EZAJCS)',
	},
];

function segmentsFor(key: MetricKey): string[] {
	const points = data
		.filter((row) => row[key] !== null)
		.map((row) => ({ x: x(row.year), y: y(row[key] as number) }));

	if (points.length < 2) return [];

	return [`M ${points.map((pt) => `${pt.x.toFixed(2)} ${pt.y.toFixed(2)}`).join(' L ')}`];
}

function pointsFor(key: MetricKey): { x: number; y: number }[] {
	return data
		.filter((row) => row[key] !== null)
		.map((row) => ({ x: x(row.year), y: y(row[key] as number) }));
}
---

<figure id="juvenile-trends-chart" class="jj-trends-chart relative left-1/2 my-10 w-[min(100vw-2rem,68rem)] max-w-none -translate-x-1/2 overflow-hidden rounded-lg border border-black/10 bg-white shadow-sm">
	<div class="border-b border-black/8 px-4 py-4 sm:px-6 sm:py-5 md:px-8">
		<p class="text-[0.68rem] font-semibold uppercase tracking-[0.18em] text-black/35">
			National Juvenile Justice Indicators
		</p>
		<h4 class="mt-1 text-[1.05rem] font-bold leading-tight text-black">
			Change in Youth Crime Indicators, 1990-2023
		</h4>
		<p class="mt-1 text-[0.82rem] leading-relaxed text-black/50">
			Three national indicators are shown as indexed trend lines over time. Graph structure is based on the Annie E. Casey Foundation reference chart
			<ReferenceSup refId={41} popoverEnabled={false} />.
		</p>

		<div class="mt-4 flex flex-nowrap items-center gap-x-4 overflow-x-auto text-[0.76rem] text-black/70 sm:gap-x-5">
			{metrics.map((metric) => (
				<span class="inline-flex items-center gap-2 whitespace-nowrap">
					<span class="h-2.5 w-5 rounded-full" style={`background:${metric.color};`}></span>
					<span>
						{metric.label}
									<ReferenceSup refId={metric.reference} popoverEnabled={false} />
					</span>
				</span>
			))}
		</div>
	</div>

	<div class="px-3 py-4 sm:px-4 sm:py-5 md:px-6">
		<svg
			viewBox={`0 0 ${WIDTH} ${HEIGHT}`}
			role="img"
			aria-label="Line chart of indexed juvenile arrests, delinquency cases, and detained youth from 1990 to 2023"
			data-series={JSON.stringify(data)}
			data-padding-left={String(PADDING.left)}
			data-padding-right={String(PADDING.right)}
			data-padding-top={String(PADDING.top)}
			data-padding-bottom={String(PADDING.bottom)}
			data-width={String(WIDTH)}
			data-height={String(HEIGHT)}
		>
			{yTicks.map((tick) => (
				<g>
					<line x1={PADDING.left} x2={WIDTH - PADDING.right} y1={y(tick)} y2={y(tick)} class="grid-line" />
					<text x={PADDING.left - 8} y={y(tick) + 4} text-anchor="end" class="axis-label">{tick}</text>
				</g>
			))}

			{xTicks.map((tick) => (
				<text x={x(tick)} y={HEIGHT - 12} text-anchor="middle" class="axis-label">{tick}</text>
			))}

			<line x1={PADDING.left} x2={WIDTH - PADDING.right} y1={HEIGHT - PADDING.bottom} y2={HEIGHT - PADDING.bottom} class="axis-line" />
			<line x1={PADDING.left} x2={PADDING.left} y1={PADDING.top} y2={HEIGHT - PADDING.bottom} class="axis-line" />
			<line id="trend-hover-line" x1={PADDING.left} x2={PADDING.left} y1={PADDING.top} y2={HEIGHT - PADDING.bottom} class="hover-guide hidden" />
			<g id="trend-hover-points"></g>

			{metrics.map((metric) => (
				<g>
					{segmentsFor(metric.key).map((segment, idx) => (
						<path
							d={segment}
							class={`trend-line ${metric.key === 'detainedYouth' ? 'trend-line-dashed' : ''}`}
							style={`--line-color: ${metric.color}; --line-delay: ${(idx + 1) * 140}ms;`}
							pathLength="1"
						/>
					))}
					{metric.key === 'detainedYouth' &&
						pointsFor(metric.key).map((pt) => (
							<g>
								<circle cx={pt.x} cy={pt.y} r="4.5" class="detained-point-outer" style={`--point-color: ${metric.color};`} />
								<circle cx={pt.x} cy={pt.y} r="2" class="detained-point-inner" />
							</g>
						))}
				</g>
			))}
		</svg>
		<div id="trend-hover-tooltip" class="trend-hover-tooltip hidden" aria-live="polite"></div>
	</div>

	<div class="border-t border-black/8 px-4 py-3 sm:px-6 md:px-8">
		<p class="text-[0.68rem] leading-relaxed text-black/35">
			Data compiled from: Council on Criminal Justice<ReferenceSup refId={7} popoverEnabled={false} /> and OJJDP EZAJCS<ReferenceSup refId={29} popoverEnabled={false} />. Graph based on Annie E. Casey Foundation chart<ReferenceSup refId={41} popoverEnabled={false} />.
		</p>
	</div>
</figure>

<style>
	.jj-trends-chart svg {
		height: auto;
		width: 100%;
		touch-action: none;
	}

	.grid-line {
		stroke: rgb(15 23 42 / 0.12);
		stroke-width: 1;
	}

	.axis-line {
		stroke: rgb(15 23 42 / 0.28);
		stroke-width: 1.1;
	}

	.axis-label {
		fill: rgb(15 23 42 / 0.55);
		font-size: 10px;
		font-variant-numeric: tabular-nums;
	}

	.trend-line {
		fill: none;
		stroke: var(--line-color);
		stroke-linecap: round;
		stroke-linejoin: round;
		stroke-width: 4;
		stroke-dasharray: 1;
		stroke-dashoffset: 1;
		opacity: 0.95;
		transition: stroke-dashoffset 1200ms cubic-bezier(0.25, 1, 0.5, 1);
		transition-delay: var(--line-delay, 0ms);
	}

	.trend-line-dashed {
		stroke-dasharray: 6 4;
		stroke-dashoffset: 10;
	}

	.detained-point-outer {
		fill: var(--point-color);
	}

	.detained-point-inner {
		fill: white;
	}

	.hover-guide {
		stroke: rgb(15 23 42 / 0.55);
		stroke-width: 1.3;
		stroke-dasharray: 5 4;
		pointer-events: none;
	}

	.trend-hover-point-outer {
		stroke: white;
		stroke-width: 1;
	}

	.trend-hover-point-inner {
		fill: white;
	}

	.trend-hover-tooltip {
		position: absolute;
		min-width: 12rem;
		max-width: min(18.5rem, calc(100vw - 2.5rem));
		pointer-events: none;
		z-index: 10;
		border: 1px solid rgb(15 23 42 / 0.16);
		background: rgb(255 255 255 / 0.96);
		box-shadow: 0 14px 28px rgb(0 0 0 / 0.16);
		padding: 0.5rem 0.6rem;
		font-size: 0.72rem;
		line-height: 1.35;
		color: rgb(15 23 42 / 0.92);
		backdrop-filter: blur(1.5px);
	}

	:global(.trend-hover-title) {
		margin: 0 0 0.25rem 0;
		font-size: 0.76rem;
		font-weight: 700;
	}

	:global(.trend-hover-row) {
		display: grid;
		grid-template-columns: auto 1fr;
		align-items: start;
		column-gap: 0.45rem;
		row-gap: 0;
		margin-top: 0.12rem;
	}

	:global(.trend-hover-key) {
		display: inline-flex;
		align-items: center;
		gap: 0.35rem;
		white-space: nowrap;
	}

	:global(.trend-hover-dot) {
		display: inline-block;
		width: 0.45rem;
		height: 0.45rem;
		border-radius: 999px;
	}

	:global(.trend-hover-value) {
		font-variant-numeric: tabular-nums;
		text-align: right;
		white-space: normal;
	}

	.jj-trends-chart.in-view .trend-line {
		stroke-dashoffset: 0;
	}
</style>

<script>
	(() => {
		const chart = document.getElementById('juvenile-trends-chart');
		if (!chart) return;
		const svg = chart.querySelector('svg');
		const hoverLine = chart.querySelector('#trend-hover-line');
		const hoverPoints = chart.querySelector('#trend-hover-points');
		const tooltip = chart.querySelector('#trend-hover-tooltip');

		if (!(svg instanceof SVGSVGElement) || !(hoverLine instanceof SVGLineElement) || !(hoverPoints instanceof SVGGElement) || !(tooltip instanceof HTMLDivElement)) {
			return;
		}

		const rows = JSON.parse(svg.dataset.series || '[]');
		if (!Array.isArray(rows) || rows.length === 0) return;

		const width = Number(svg.dataset.width || 0);
		const height = Number(svg.dataset.height || 0);
		const paddingLeft = Number(svg.dataset.paddingLeft || 0);
		const paddingRight = Number(svg.dataset.paddingRight || 0);
		const paddingTop = Number(svg.dataset.paddingTop || 0);
		const paddingBottom = Number(svg.dataset.paddingBottom || 0);
		const innerWidth = width - paddingLeft - paddingRight;

		const years = rows.map((row) => row.year);
		const minYear = Math.min(...years);
		const maxYear = Math.max(...years);
		const metrics: Array<{ key: HoverMetricKey; label: string; color: string }> = [
			{ key: 'juvenileArrests', label: 'Juvenile arrests', color: '#b91c1c' },
			{ key: 'delinquency', label: 'Delinquency cases', color: '#0f766e' },
			{ key: 'detainedYouth', label: 'Detained youth', color: '#1d4ed8' },
		];

		const numericValues = rows
			.flatMap((row) => [row.delinquency, row.juvenileArrests, row.detainedYouth])
			.filter((value) => typeof value === 'number' && Number.isFinite(value));
		const yMin = Math.floor((Math.min(...numericValues) - 10) / 10) * 10;
		const yMax = Math.ceil((Math.max(...numericValues) + 10) / 10) * 10;

		type HoverMetricKey = 'juvenileArrests' | 'delinquency' | 'detainedYouth';
		const xForYear = (year: number) => paddingLeft + ((year - minYear) / (maxYear - minYear)) * innerWidth;
		const yForValue = (value: number) => paddingTop + ((yMax - value) / (yMax - yMin)) * (height - paddingTop - paddingBottom);

		const formatTrend = (rowIndex: number, key: HoverMetricKey) => {
			const current = rows[rowIndex][key];
			if (current == null) return { valueLabel: 'n/a', trendLabel: 'no data' };

			let prev = null;
			for (let i = rowIndex - 1; i >= 0; i--) {
				if (rows[i][key] != null) {
					prev = rows[i][key];
					break;
				}
			}

			if (prev == null) return { valueLabel: `${current.toFixed(1)}`, trendLabel: 'first point' };

			const delta = current - prev;
			if (delta === 0) return { valueLabel: `${current.toFixed(1)}`, trendLabel: 'flat vs prior' };
			const direction = delta > 0 ? 'up' : 'down';
			return {
				valueLabel: `${current.toFixed(1)}`,
				trendLabel: `${direction} ${Math.abs(delta).toFixed(1)} vs prior`,
			};
		};

		const clearHoverPoints = () => {
			while (hoverPoints.firstChild) hoverPoints.removeChild(hoverPoints.firstChild);
		};

		const showAtClientPosition = (clientX: number, clientY: number) => {
			const svgRect = svg.getBoundingClientRect();
			const chartRect = chart.getBoundingClientRect();
			const px = Math.max(svgRect.left, Math.min(clientX, svgRect.right));
			const ratio = (px - svgRect.left) / svgRect.width;
			const xPos = paddingLeft + ratio * (width - paddingLeft - paddingRight);
			const yearFloat = minYear + ((xPos - paddingLeft) / innerWidth) * (maxYear - minYear);
			let closestIndex = 0;
			let closestDiff = Number.POSITIVE_INFINITY;

			for (let i = 0; i < rows.length; i++) {
				const diff = Math.abs(rows[i].year - yearFloat);
				if (diff < closestDiff) {
					closestDiff = diff;
					closestIndex = i;
				}
			}

			const row = rows[closestIndex];
			const guideX = xForYear(row.year);

			hoverLine.setAttribute('x1', guideX.toFixed(2));
			hoverLine.setAttribute('x2', guideX.toFixed(2));
			hoverLine.classList.remove('hidden');

			clearHoverPoints();
			metrics.forEach((metric) => {
				const value = row[metric.key];
				if (value == null) return;
				const yPos = yForValue(value);

				const outer = document.createElementNS('http://www.w3.org/2000/svg', 'circle');
				outer.setAttribute('cx', guideX.toFixed(2));
				outer.setAttribute('cy', yPos.toFixed(2));
				outer.setAttribute('r', '4.7');
				outer.setAttribute('fill', metric.color);
				outer.setAttribute('class', 'trend-hover-point-outer');

				const inner = document.createElementNS('http://www.w3.org/2000/svg', 'circle');
				inner.setAttribute('cx', guideX.toFixed(2));
				inner.setAttribute('cy', yPos.toFixed(2));
				inner.setAttribute('r', '2');
				inner.setAttribute('class', 'trend-hover-point-inner');

				hoverPoints.appendChild(outer);
				hoverPoints.appendChild(inner);
			});

			const rowsHtml = metrics
				.map((metric) => {
					const trend = formatTrend(closestIndex, metric.key);
					return `<div class="trend-hover-row"><span class="trend-hover-key"><span class="trend-hover-dot" style="background:${metric.color}"></span>${metric.label}</span><span class="trend-hover-value">${trend.valueLabel} (${trend.trendLabel})</span></div>`;
				})
				.join('');

			tooltip.innerHTML = `<p class="trend-hover-title">Year ${row.year}</p>${rowsHtml}`;
			tooltip.classList.remove('hidden');

			const preferredLeft = clientX - chartRect.left + 14;
			const preferredTop = clientY - chartRect.top - 14;
			const maxLeft = chartRect.width - tooltip.offsetWidth - 8;
			const maxTop = chartRect.height - tooltip.offsetHeight - 8;
			const finalLeft = Math.max(8, Math.min(preferredLeft, maxLeft));
			const finalTop = Math.max(8, Math.min(preferredTop, maxTop));
			tooltip.style.left = `${finalLeft}px`;
			tooltip.style.top = `${finalTop}px`;
		};

		const hideHover = () => {
			hoverLine.classList.add('hidden');
			clearHoverPoints();
			tooltip.classList.add('hidden');
		};

		svg.addEventListener('pointermove', (event) => {
			showAtClientPosition(event.clientX, event.clientY);
		});

		svg.addEventListener('pointerleave', hideHover);

		const observer = new IntersectionObserver(
			([entry]) => {
				if (!entry.isIntersecting) return;
				chart.classList.add('in-view');
				observer.disconnect();
			},
			{ threshold: 0.2 },
		);

		observer.observe(chart);
	})();
</script>
