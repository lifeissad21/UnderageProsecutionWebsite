---
import ReferenceSup from '../ReferenceSup.astro';

type DiversionRow = {
	category: string;
	whiteYouth: number;
	blackYouth: number;
	emphasize?: boolean;
};

const WHITE_COLOR = '#64748b';
const BLACK_COLOR = '#c1121f';

const MAX = 80;
const rows: DiversionRow[] = [
	{ category: 'All Offenses', whiteYouth: 49, blackYouth: 37, emphasize: true },
	{ category: 'Violent Crime Index', whiteYouth: 26, blackYouth: 19 },
	{ category: 'Property Crime Index', whiteYouth: 42, blackYouth: 37 },
	{ category: 'Public Order Offenses', whiteYouth: 46, blackYouth: 37 },
	{ category: 'Drug Offenses', whiteYouth: 61, blackYouth: 46 },
];

const widthPct = (value: number): string => `${((value / MAX) * 100).toFixed(3)}%`;
---

<figure
	id="diversion-race-chart"
	class="diversion-race-chart my-2 overflow-hidden rounded-lg border border-black/10 bg-white shadow-sm"
	aria-label="Share of delinquency cases diverted in 2021 by race for selected offense categories"
	role="figure"
>
	<div class="border-b border-black/8 px-4 py-4 sm:px-6 sm:py-5 md:px-8">
		<p class="text-[0.68rem] font-semibold uppercase tracking-[0.18em] text-black/35">
			Diversion Rates by Race
		</p>
		<h4 class="mt-1 text-[1.05rem] font-bold leading-tight text-black">
			Share of Delinquency Cases Diverted in 2021
		</h4>
		<p class="mt-0.5 text-[0.82rem] text-black/45">
			Selected offense categories.
		</p>

		<div class="mt-3 flex flex-wrap items-center gap-3 text-[0.72rem] font-semibold text-black/60 sm:mt-4 sm:gap-5 sm:text-[0.75rem]">
			<span class="flex items-center gap-1.5">
				<span class="inline-block h-2.5 w-4 rounded-sm" style={`background:${WHITE_COLOR};`}></span>
				White Youth
			</span>
			<span class="flex items-center gap-1.5">
				<span class="inline-block h-2.5 w-4 rounded-sm" style={`background:${BLACK_COLOR};`}></span>
				Black Youth
			</span>
		</div>
	</div>

	<div class="px-4 py-5 sm:px-6 sm:py-6 md:px-8">
		<ul class="m-0 list-none space-y-6 p-0" role="list">
			{rows.map((row, i) => (
				<li class="race-row" style={`--i: ${i};`}>
					<div class="mb-2">
						<span class:list={['text-[0.88rem] font-bold', row.emphasize ? 'text-[#c1121f]' : 'text-black']}>
							{row.category}
						</span>
					</div>

					<div class="mb-2 flex items-center gap-3">
						<span class="w-16 shrink-0 text-right text-[10px] font-semibold uppercase tracking-wide text-black/35">
							White
						</span>
						<div class="relative h-7 flex-1 overflow-hidden rounded-md bg-black/[0.05]">
							<div
								class="bar absolute inset-y-0 left-0 rounded-md"
								style={`--w: ${widthPct(row.whiteYouth)}; --delay: ${i * 95}ms; background:${WHITE_COLOR};`}
							></div>
						</div>
						<span class="w-10 shrink-0 text-right text-[0.8rem] font-bold tabular-nums" style={`color:${WHITE_COLOR};`}>
							{row.whiteYouth}%
						</span>
					</div>

					<div class="flex items-center gap-3">
						<span class="w-16 shrink-0 text-right text-[10px] font-semibold uppercase tracking-wide text-black/35">
							Black
						</span>
						<div class="relative h-7 flex-1 overflow-hidden rounded-md bg-black/[0.05]">
							<div
								class="bar absolute inset-y-0 left-0 rounded-md"
								style={`--w: ${widthPct(row.blackYouth)}; --delay: ${i * 95 + 80}ms; background:${BLACK_COLOR};`}
							></div>
						</div>
						<span class="w-10 shrink-0 text-right text-[0.8rem] font-bold tabular-nums" style={`color:${BLACK_COLOR};`}>
							{row.blackYouth}%
						</span>
					</div>
				</li>
			))}
		</ul>

		<div aria-hidden="true" class="ml-[5.4rem] mt-4 flex justify-between border-t border-black/8 pt-2">
			{[0, 20, 40, 60, 80].map((tick) => (
				<span class="text-[9px] tabular-nums text-black/25">{tick}%</span>
			))}
		</div>
	</div>

	<div class="border-t border-black/8 px-4 py-3 sm:px-6 md:px-8">
		<p class="text-[0.65rem] leading-relaxed text-black/30">
			Values shown are percentages for White Youth and Black Youth diverted in 2021 across selected offense categories.
			Source: The Sentencing Project <ReferenceSup refId={16} popoverEnabled={false} />.
		</p>
	</div>
</figure>

<style>
	.bar {
		width: 0;
		transition: width 900ms cubic-bezier(0.25, 1, 0.5, 1);
		transition-delay: var(--delay, 0ms);
	}

	.diversion-race-chart.in-view .bar {
		width: var(--w);
	}

	.race-row {
		opacity: 0;
		transform: translateX(-14px);
		transition: opacity 520ms ease, transform 520ms ease;
		transition-delay: calc(var(--i, 0) * 85ms);
	}

	.diversion-race-chart.in-view .race-row {
		opacity: 1;
		transform: translateX(0);
	}
</style>

<script>
	(() => {
		const chart = document.getElementById('diversion-race-chart');
		if (!chart) return;

		if ('IntersectionObserver' in window) {
			const observer = new IntersectionObserver(
				([entry]) => {
					if (!entry.isIntersecting) return;
					chart.classList.add('in-view');
					observer.disconnect();
				},
				{ threshold: 0.16 },
			);
			observer.observe(chart);
		} else {
			chart.classList.add('in-view');
		}
	})();
</script>
