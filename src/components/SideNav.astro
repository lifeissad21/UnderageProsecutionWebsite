---
const TRACK_HEIGHT = 280;
const PAD = 32;

const sections = [
	{ id: 'intro',       label: 'Introduction' },
	{ id: 'history',     label: 'Ch. 1 — History' },
	{ id: 'prosecution', label: 'Ch. 2 — Prosecution' },
	{ id: 'issues',      label: 'Ch. 3 — Issues' },
	{ id: 'conclusion',  label: 'Conclusion' },
];
---
<nav
	id="side-nav"
	aria-label="Article sections"
	class="group pointer-events-none fixed left-0 top-1/2 z-40 hidden -translate-y-1/2 opacity-0 transition-opacity duration-500 md:block"
	style={`width: 220px; height: ${TRACK_HEIGHT + PAD * 2}px;`}
>
	<div
		class="absolute w-px bg-black/20"
		style={`left: 24px; top: ${PAD}px; bottom: ${PAD}px;`}
	></div>

	<div
		id="snr-fill"
		class="absolute w-px bg-black"
		style={`left: 24px; top: ${PAD}px; height: 0px; transition: height 180ms ease-out;`}
	></div>

	{sections.map((section, i) => {
		const top = PAD + (i === 0 ? 0 : (i / (sections.length - 1)) * TRACK_HEIGHT);
		return (
			<a
				href={`#${section.id}`}
				class="absolute flex -translate-y-1/2 items-center text-black transition-transform duration-200 hover:translate-x-2 hover:text-[#780000]"
				style={`top: ${top}px; left: 34px;`}
			>
				<span class="snr-label inline-block whitespace-nowrap text-[11px] font-semibold uppercase tracking-[0.12em] text-current opacity-0 transition-opacity duration-300 group-hover:opacity-100">
					{section.label}
				</span>
			</a>
		);
	})}
</nav>

<script>
	(() => {
		const nav   = document.getElementById('side-nav');
		const fill  = document.getElementById('snr-fill');
		const hero  = document.getElementById('hero');
		const TRACK = 280;
		const IDS   = ['intro', 'history', 'prosecution', 'issues', 'conclusion'];

		function getEl(id: string): HTMLElement | null {
			return document.getElementById(id);
		}

		function update() {
			if (!fill || !nav) return;

			if (hero) {
				const heroBottom = hero.getBoundingClientRect().bottom;
				if (heroBottom <= 0) {
					nav.style.opacity = '1';
					nav.classList.remove('pointer-events-none');
				} else {
					nav.style.opacity = '0';
					nav.classList.add('pointer-events-none');
					return;
				}
			}

			const dividers = document.querySelectorAll('.chapter-divider');
			const anyDividerVisible = Array.from(dividers).some((d) => {
				const rect = d.getBoundingClientRect();
				return rect.top < window.innerHeight && rect.bottom > 0;
			});
			if (anyDividerVisible) {
				nav.style.opacity = '0';
				nav.classList.add('pointer-events-none');
				return;
			}

			const first = getEl(IDS[0]);
			const last  = getEl(IDS[IDS.length - 1]);
			if (!first || !last) return;

			const scrollY  = window.scrollY;
			const mid      = scrollY + window.innerHeight * 0.5;
			const start    = first.getBoundingClientRect().top + scrollY;
			const end      = last.getBoundingClientRect().top  + scrollY + last.getBoundingClientRect().height;
			const progress = Math.max(0, Math.min(1, (mid - start) / (end - start)));

			fill.style.height = `${progress * TRACK}px`;
		}

		window.addEventListener('scroll', update, { passive: true });
		window.addEventListener('load', update);
		update();
	})();
</script>
