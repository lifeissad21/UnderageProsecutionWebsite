---
import { formattedReferences } from '../data/formattedReferences';
---

<section id="references" class="mx-auto max-w-2xl px-6 py-24">
	<h2 class="text-2xl font-bold text-black">References</h2>
	<ol class="mt-3 list-decimal space-y-4 pl-6 text-base leading-relaxed text-black">
		{formattedReferences.map((citation, index) => (
			<li id={`reference-${index + 1}`} class="reference-item">
				<div class="reference-entry mb-1" set:html={citation}></div>
			</li>
		))}
	</ol>
	<button
		type="button"
		data-return-reading
		aria-label="Return to previous reading position"
		title="Return to previous reading position"
		class="hidden fixed right-4 top-1/2 z-40 h-12 w-12 -translate-y-1/2 items-center justify-center rounded-full border border-black/15 bg-white text-2xl font-bold leading-none text-[#780000] shadow-lg transition-colors hover:bg-[#fff4f4] hover:text-[#c1121f]"
	>
		<span aria-hidden="true">↑</span>
	</button>
</section>

<style>
	/* APA format styling */
	ol {
		list-style: none;
		counter-reset: item;
		padding-left: 0;
	}

	li {
		counter-increment: item;
		margin-bottom: 1rem;
	}

	.reference-entry {
		--hanging-indent: 2rem;
		display: block;
		padding-left: calc(var(--hanging-indent) + 1rem);
		padding-right: 1.5rem;
		padding-top: 0.75rem;
		padding-bottom: 0.75rem;
		text-indent: calc(-1 * var(--hanging-indent));
		border-radius: 0.375rem;
		background-color: transparent;
		white-space: normal;
		overflow-wrap: anywhere;
		word-break: break-word;
	}

	.reference-entry :global(a) {
		color: #780000;
		text-decoration: underline;
		overflow-wrap: anywhere;
		word-break: break-word;
	}

	.reference-entry :global(a:hover) {
		color: #c1121f;
	}

	.reference-entry :global(i) {
		font-style: italic;
	}

	.reference-item:target .reference-entry {
		animation: reference-highlight-fade 4s ease-out forwards;
	}

	.reference-item.is-highlighted .reference-entry {
		animation: reference-highlight-fade 4s ease-out forwards;
	}

	.reference-item:target {
		scroll-margin-top: 5.5rem;
	}

	@keyframes reference-highlight-fade {
		0% {
			background-color: #fef08a;
		}
		65% {
			background-color: #fef9c3;
		}
		100% {
			background-color: transparent;
		}
	}
</style>

<script>
	(() => {
		const RETURN_Y_KEY = 'referenceReturnY';
		let isInReferencesSection = false;
		const refItems = Array.from(document.querySelectorAll<HTMLElement>('#references .reference-item'));
		const returnButton = document.querySelector<HTMLButtonElement>('[data-return-reading]');
		const referencesSection = document.getElementById('references');

		const highlightFromHash = () => {
			const hash = window.location.hash;
			if (!hash.startsWith('#reference-')) {
				return;
			}

			const target = document.getElementById(hash.slice(1));
			if (!target || !target.classList.contains('reference-item')) {
				return;
			}

			refItems.forEach((item) => item.classList.remove('is-highlighted'));
			void target.getBoundingClientRect();
			target.classList.add('is-highlighted');
		};

		const toggleReturnButton = () => {
			if (!returnButton) return;
			const hasStoredPosition = sessionStorage.getItem(RETURN_Y_KEY) !== null;
			const isAtPageBottom = window.innerHeight + window.scrollY >= document.documentElement.scrollHeight - 2;
			const shouldShow = hasStoredPosition && (isInReferencesSection || isAtPageBottom);
			returnButton.classList.toggle('hidden', !shouldShow);
			returnButton.classList.toggle('flex', shouldShow);
		};

		if (returnButton) {
			returnButton.addEventListener('click', () => {
				const raw = sessionStorage.getItem(RETURN_Y_KEY);
				if (!raw) return;
				const y = Number(raw);
				if (Number.isNaN(y)) return;

				window.scrollTo({ top: Math.max(0, y), behavior: 'smooth' });
				sessionStorage.removeItem(RETURN_Y_KEY);
				setTimeout(() => {
					history.replaceState(null, '', window.location.pathname + window.location.search);
					toggleReturnButton();
				}, 300);
			});
		}

		window.addEventListener('hashchange', () => {
			highlightFromHash();
			toggleReturnButton();
		});

		window.addEventListener('scroll', () => {
			toggleReturnButton();
		}, { passive: true });

		if (referencesSection && 'IntersectionObserver' in window) {
			const sectionObserver = new IntersectionObserver(
				([entry]) => {
					isInReferencesSection = entry.isIntersecting;
					toggleReturnButton();
				},
				{ threshold: 0.15 },
			);
			sectionObserver.observe(referencesSection);
		}

		window.addEventListener('load', () => {
			highlightFromHash();
			toggleReturnButton();
		});

		highlightFromHash();
		toggleReturnButton();
	})();
</script>
