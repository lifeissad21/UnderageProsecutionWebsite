---
import HeroSection from '../components/HeroSection.astro';
import SideNav from '../components/SideNav.astro';
import HeaderNav from '../components/HeaderNav.astro';
import ChapterIntro from '../components/chapters/ChapterIntro.astro';
import ChapterHistory from '../components/chapters/ChapterHistory.astro';
import ChapterCurrentProsecution from '../components/chapters/ChapterCurrentProsecution.astro';
import ChapterIssues from '../components/chapters/ChapterIssues.astro';
import ChapterConclusion from '../components/chapters/ChapterConclusion.astro';
import '../styles/global.css'
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>Underage Prosecution Article</title>
	</head>
	<body class="bg-[#f7f5f2] text-black antialiased">
		<HeaderNav />

		<SideNav />

		<main>
			<HeroSection />

			<ChapterIntro />
			<ChapterHistory />
			<ChapterCurrentProsecution />
			<ChapterIssues />
			<ChapterConclusion />

			<section id="references" class="mx-auto max-w-2xl px-6 py-24">
				<h3 class="text-2xl font-bold text-black">References</h3>
				<h4 class="mt-6 text-sm font-semibold uppercase tracking-[0.14em] text-black/60">Hero Image Sources</h4>
				<ol class="mt-3 list-decimal space-y-4 pl-6 text-base leading-relaxed text-black">
					<li>
						Original title phrase image:
						<a class="ml-1 underline hover:text-[#780000]" href="https://platform.vox.com/wp-content/uploads/sites/2/chorus/uploads/chorus_asset/file/14724701/1148455.0.1412957860.jpg?quality=90&strip=all&crop=0,0.86705202312138,100,98.265895953757" target="_blank" rel="noopener noreferrer">
							Image link
						</a>
						|
						<a class="ml-1 underline hover:text-[#780000]" href="https://www.vox.com/2014/5/22/5740168/charging-teenagers-as-adults-direct-file-safety-recidivism-juvenile-justice" target="_blank" rel="noopener noreferrer">
							Source page
						</a>
					</li>
					<li>
						Too young to vote image A:
						<a class="ml-1 underline hover:text-[#780000]" href="https://ca-times.brightspotcdn.com/dims4/default/193b845/2147483647/strip/false/crop/4228x2808+0+0/resize/1486x987!/quality/75/?url=https%3A%2F%2Fcalifornia-times-brightspot.s3.amazonaws.com%2F23%2F4d%2Ff7c760be45b8a1788ed64b565711%2Fap070315057151.jpg" target="_blank" rel="noopener noreferrer">
							Image link
						</a>
						|
						<a class="ml-1 underline hover:text-[#780000]" href="https://www.latimes.com/california/story/2021-02-15/california-youth-prisons-closing-criminal-justice-reform" target="_blank" rel="noopener noreferrer">
							Source page
						</a>
					</li>
					<li>
						Too young to vote image B:
						<a class="ml-1 underline hover:text-[#780000]" href="https://childrensdefense.org/wp-content/uploads/2023/10/2023-SOAC-Hero-Youth-Justice.jpg" target="_blank" rel="noopener noreferrer">
							Image link
						</a>
						|
						<a class="ml-1 underline hover:text-[#780000]" href="https://childrensdefense.org/tools-and-resources/the-state-of-americas-children/soac-youth-justice/" target="_blank" rel="noopener noreferrer">
							Source page
						</a>
					</li>
					<li>
						Old enough to be sentenced image:
						<a class="ml-1 underline hover:text-[#780000]" href="https://www.gpb.org/sites/default/files/styles/flexheight/public/npr_story_images/2020/07/14/scared_014_0.JPG?itok=bOw4fI6f" target="_blank" rel="noopener noreferrer">
							Image link
						</a>
						|
						<a class="ml-1 underline hover:text-[#780000]" href="https://www.gpb.org/news/2016/09/14/can-kids-be-scared-straight" target="_blank" rel="noopener noreferrer">
							Source page
						</a>
					</li>
					<li>
						This is juvenile justice image:
						<a class="ml-1 underline hover:text-[#780000]" href="https://www.cincinnati.com/gcdn/presto/2023/08/15/NCOD/58098121-b45c-45f6-bea0-213212ad0558-01_released_video.00_03_15_07.Still003.jpg?crop=1275,718,x2,y0&width=660&height=371&format=pjpg&auto=webp" target="_blank" rel="noopener noreferrer">
							Image link
						</a>
						|
						<a class="ml-1 underline hover:text-[#780000]" href="https://www.cincinnati.com/story/news/2023/11/11/ohios-youth-prison-detention-centers-struggle-with-injuries-neglect/70410221007/" target="_blank" rel="noopener noreferrer">
							Source page
						</a>
					</li>
				</ol>
			</section>
		</main>

		<footer class="border-t border-black/10 bg-[#f7f5f2]">
			<div class="mx-auto flex max-w-6xl flex-col gap-3 px-6 py-8 text-sm text-black/40 md:flex-row md:items-center md:justify-between">
				<p>Underage Prosecution Website Skeleton</p>
				<p>Updated for legal article structure and scroll-aware navigation</p>
			</div>
		</footer>

		<script>
			const header = document.querySelector('#site-header');
			const hero = document.querySelector('#hero');
			const chapterDividers = document.querySelectorAll('.chapter-divider');
			const chapterLabel = document.querySelector('#current-chapter');
			const chapterMap = [
				{ id: 'intro',               label: 'Introduction' },
				{ id: 'chapter-history',     label: 'Chapter 1 — History' },
				{ id: 'history',             label: 'Chapter 1 — History' },
				{ id: 'chapter-prosecution', label: 'Chapter 2 — Current Prosecution' },
				{ id: 'prosecution',         label: 'Chapter 2 — Current Prosecution' },
				{ id: 'chapter-issues',      label: 'Chapter 3 — Current Issues' },
				{ id: 'issues',              label: 'Chapter 3 — Current Issues' },
				{ id: 'chapter-conclusion',  label: 'Conclusion' },
				{ id: 'conclusion',          label: 'Conclusion' },
				{ id: 'references',          label: 'References' },
			];

			let heroInView = true;
			let headerIsVisible = false;

			const updateHeaderVisibility = () => {
				if (!header) return;
				const h = header as HTMLElement;
				const headerH = h.clientHeight;
				const dividerAtHeader = Array.from(chapterDividers).some((d) => {
					const rect = d.getBoundingClientRect();
					return rect.top < headerH && rect.bottom > 0;
				});

				const shouldShow = !heroInView && !dividerAtHeader;

				if (shouldShow && !headerIsVisible) {
					headerIsVisible = true;
					h.classList.remove('invisible');
					h.style.transition = 'opacity 450ms ease-out';
					requestAnimationFrame(() => requestAnimationFrame(() => { h.style.opacity = '1'; }));
				} else if (!shouldShow && headerIsVisible) {
					headerIsVisible = false;
					if (dividerAtHeader) {
						// Divider is physically covering the header — hide instantly
						h.style.transition = 'none';
						h.style.opacity = '0';
					} else {
						// Hero scrolling back into view — fade out
						h.style.transition = 'opacity 350ms ease-in';
						h.style.opacity = '0';
					}
				} else if (!shouldShow) {
					h.classList.add('invisible');
				}
			};

			if (header && hero) {
				const observer = new IntersectionObserver(
					(entries) => {
						const [entry] = entries;
						heroInView = entry.isIntersecting;
						updateHeaderVisibility();
					},
					{
						threshold: 0.2,
					}
				);

				observer.observe(hero);
			}

			if (chapterDividers.length > 0) {
				const chapterObserver = new IntersectionObserver(
					(entries) => {
						entries.forEach((entry) => {
							entry.target.classList.toggle('in-view', entry.isIntersecting);
						});
					},
					{
						threshold: 0.45,
					}
				);

				chapterDividers.forEach((divider) => {
					chapterObserver.observe(divider);
				});
			}

			const updateChapterLabel = () => {
				if (!chapterLabel) return;

				let active = chapterMap[0];

				chapterMap.forEach((item) => {
					const el = document.getElementById(item.id);
					if (!el) return;
					const rect = el.getBoundingClientRect();
					// For chapter dividers, only trigger once their top edge has reached
					// the top of the viewport (halfway through scrolling the full-screen divider).
					// For regular sections, trigger when their top passes 35% down the screen.
					const triggered = el.classList.contains('chapter-divider')
						? rect.top <= 0
						: rect.top <= window.innerHeight * 0.35;
					if (triggered) active = item;
				});

				const current = chapterLabel.textContent?.trim();
				if (current === active.label) return;

				if (!headerIsVisible) {
					// Header is off-screen — swap text silently with no animation
					chapterLabel.textContent = active.label;
					return;
				}

				chapterLabel.classList.add('opacity-0');
				setTimeout(() => {
					chapterLabel.textContent = active.label;
					chapterLabel.classList.remove('opacity-0');
				}, 200);
			};

			const setupReferenceCopy = () => {
				const copyButtons = document.querySelectorAll<HTMLButtonElement>('[data-copy-link]');
				copyButtons.forEach((button) => {
					button.addEventListener('click', async () => {
						const link = button.getAttribute('data-copy-link');
						if (!link) return;
						await navigator.clipboard.writeText(link);
						button.classList.add('bg-black', 'text-white');
						const status = button.parentElement?.querySelector('[data-copy-status]');
						status?.classList.remove('opacity-0');
						button.blur();
						setTimeout(() => {
							button.classList.remove('bg-black', 'text-white');
							status?.classList.add('opacity-0');
						}, 1200);
					});
				});
			};

			window.addEventListener('scroll', () => { updateChapterLabel(); updateHeaderVisibility(); }, { passive: true });
			window.addEventListener('load', () => { updateChapterLabel(); updateHeaderVisibility(); });
			updateChapterLabel();
			updateHeaderVisibility();
			setupReferenceCopy();
		</script>

		<style is:global>
			@media (max-width: 1023px) {
				#side-nav {
					display: none !important;
				}

				#intro,
				#history,
				#prosecution,
				#issues,
				#conclusion,
				#references {
					max-width: none !important;
					width: 100%;
					padding-left: 1rem !important;
					padding-right: 1rem !important;
				}

				#hero,
				.chapter-divider {
					padding-left: 1rem;
					padding-right: 1rem;
				}
			}

			@media (max-width: 767px) {
				#site-header {
					display: none !important;
				}
			}

			@media (max-height: 700px) {
				#side-nav {
					display: none !important;
				}
			}
		</style>
	</body>
</html>
